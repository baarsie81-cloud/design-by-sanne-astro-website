---
import siteSettings from "../data/siteSettings.json";

const { emailAddress, instagramUrl, linkedinUrl, termsUrl } = siteSettings;
---

<footer class="footer">
  <div class="footer-main">
    <div class="footer-brand">
      <img src="/assets/designbysanne/logo-dbs-blue.png" alt="Design by Sanne - strategie marketing communicatie" />
    </div>

    <nav class="footer-nav" aria-label="Footer menu">
      <a href="/">Home</a>
      <a href="/diensten/">Diensten</a>
      <a href="/over-mij/">Over mij</a>
      <a href="/contact/">Contact</a>
    </nav>

    <div class="footer-socials" aria-label="Sociale links">
      <a href={instagramUrl} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="1"></circle>
        </svg>
      </a>
      <a href={`mailto:${emailAddress}`} aria-label="E-mail">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M4 6h16v12H4z"></path>
          <path d="m4 7 8 6 8-6"></path>
        </svg>
      </a>
      <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg aria-hidden="true" viewBox="0 0 24 24">
          <path d="M5 9h4v10H5z"></path>
          <path d="M5 5.5h4v.1H5z"></path>
          <path d="M13 9h3.7v1.5c.6-1 1.6-1.8 3.1-1.8 2.3 0 4.2 1.5 4.2 4.8V19h-4v-5c0-1.4-.5-2.2-1.7-2.2-1.1 0-1.7.7-1.7 2.2v5H13z"></path>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-legal">
    <a
      href={termsUrl}
      target="_blank"
      rel="noopener noreferrer"
    >
      Algemene voorwaarden
    </a>
  </div>
</footer>
