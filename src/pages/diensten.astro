---
import BaseLayout from "../layouts/BaseLayout.astro";
import dienstenContent from "../data/diensten.json";
import siteSettings from "../data/siteSettings.json";

const {
  seoTitle,
  seoDescription,
  ogDescription,
  kicker,
  heroTitle,
  heroIntro,
  heroButtonLabel,
  heroImage,
  heroImageAlt,
  statementText,
  overviewKicker,
  overviewTitle,
  overviewIntro,
  services,
  processKicker,
  processTitle,
  steps,
  ctaKicker,
  ctaTitle,
  ctaText,
  ctaButtonLabel,
} = dienstenContent;

const { calendlyUrl } = siteSettings;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical="https://designbysanne.nl/diensten/"
  ogTitle={seoTitle}
  ogDescription={ogDescription}
  ogImage={heroImage}
>
  <main>
    <section class="services-hero" aria-labelledby="services-title">
      <div class="services-hero-inner">
        <div class="services-hero-copy">
          <p class="services-kicker">{kicker}</p>
          <h1 id="services-title">{heroTitle}</h1>
          <p>{heroIntro}</p>
          <a class="button button-primary" href={calendlyUrl}>{heroButtonLabel}</a>
        </div>
        <figure class="services-hero-visual">
          <img
            src={heroImage}
            alt={heroImageAlt}
          />
        </figure>
      </div>
    </section>

    <section class="services-intro" aria-label="Voor wie">
      <p>{statementText}</p>
    </section>

    <section class="services-section" aria-labelledby="services-overview">
      <div class="section-heading">
        <p class="services-kicker">{overviewKicker}</p>
        <h2 id="services-overview">{overviewTitle}</h2>
        <p>{overviewIntro}</p>
      </div>

      <div class="services-grid">
        {
          services.map((service) => (
            <article class="service-card">
              <span>{service.number}</span>
              <h3>{service.title}</h3>
              <p>{service.text}</p>
              <ul>
                {service.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </section>

    <section class="process-section" aria-labelledby="process-title">
      <div class="section-heading section-heading-dark">
        <p class="services-kicker">{processKicker}</p>
        <h2 id="process-title">{processTitle}</h2>
      </div>
      <div class="process-grid">
        {
          steps.map((step) => (
            <article>
              <span>{step.label}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="services-cta" id="kennismaken" aria-labelledby="services-contact-title">
      <div>
        <p class="services-kicker">{ctaKicker}</p>
        <h2 id="services-contact-title">{ctaTitle}</h2>
        <p>{ctaText}</p>
      </div>
      <a class="button button-primary" href={calendlyUrl}>{ctaButtonLabel}</a>
    </section>
  </main>
</BaseLayout>

<style>
  .services-hero {
    min-height: 74vh;
    display: flex;
    align-items: center;
    padding: 190px 24px 82px;
    background:
      linear-gradient(90deg, rgba(32, 40, 47, 0.96), rgba(32, 40, 47, 0.76)),
      radial-gradient(circle at 82% 24%, rgba(220, 163, 38, 0.3), transparent 34%),
      #20282f;
    color: #ffffff;
  }

  .services-hero-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.78fr);
    gap: 56px;
    align-items: center;
  }

  .services-hero-copy {
    padding-bottom: 6px;
  }

  .services-hero-visual {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
  }

  .services-hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(32, 40, 47, 0.02), rgba(32, 40, 47, 0.24));
    pointer-events: none;
  }

  .services-hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .services-kicker {
    margin: 0 0 14px;
    color: #dca326;
    font-size: 15px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .services-hero h1 {
    margin-bottom: 24px;
    font-size: 68px;
    line-height: 1;
    font-weight: 900;
  }

  .services-hero p:not(.services-kicker) {
    margin-bottom: 34px;
    color: rgba(255, 255, 255, 0.86);
    font-size: 22px;
    line-height: 1.55;
  }

  .services-intro {
    background: #627727;
    color: #ffffff;
  }

  .services-intro p {
    width: min(1060px, calc(100% - 48px));
    margin: 0 auto;
    padding: 34px 0;
    font-size: 26px;
    line-height: 1.42;
    font-weight: 800;
  }

  .services-section {
    padding: 94px 24px;
    background: #f5f4ef;
  }

  .section-heading {
    width: min(860px, 100%);
    margin: 0 auto 42px;
    text-align: center;
  }

  .section-heading h2,
  .services-cta h2 {
    margin-bottom: 18px;
    color: #1f2a2f;
    font-size: 46px;
    line-height: 1.08;
    font-weight: 900;
  }

  .section-heading p:not(.services-kicker),
  .services-cta p:not(.services-kicker) {
    color: #586167;
    font-size: 19px;
    line-height: 1.65;
  }

  .services-grid {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .service-card {
    min-height: 330px;
    padding: 28px;
    border: 1px solid rgba(32, 40, 47, 0.12);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(32, 40, 47, 0.08);
  }

  .service-card:nth-child(5) {
    grid-column: 1 / -1;
  }

  .service-card span {
    display: block;
    margin-bottom: 46px;
    color: #9a4d42;
    font-size: 18px;
    font-weight: 900;
  }

  .service-card h3 {
    margin-bottom: 14px;
    color: #627727;
    font-size: 27px;
    line-height: 1.18;
  }

  .service-card p,
  .service-card li {
    color: #586167;
    line-height: 1.62;
  }

  .service-card p {
    margin-bottom: 18px;
  }

  .service-card ul {
    margin: 0;
    padding-left: 20px;
  }

  .service-card li + li {
    margin-top: 7px;
  }

  .process-section {
    padding: 94px 24px;
    background: #20282f;
    color: #ffffff;
  }

  .section-heading-dark h2 {
    color: #ffffff;
  }

  .process-grid {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .process-grid article {
    min-height: 238px;
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
  }

  .process-grid span {
    display: block;
    margin-bottom: 48px;
    color: #dca326;
    font-weight: 900;
  }

  .process-grid h3 {
    margin-bottom: 12px;
    font-size: 25px;
  }

  .process-grid p {
    margin-bottom: 0;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.62;
  }

  .services-cta {
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding: 86px 0;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 36px;
    align-items: center;
  }

  .services-cta p:not(.services-kicker) {
    max-width: 720px;
    margin-bottom: 0;
  }

  @media (max-width: 980px) {
    .services-hero-inner {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .services-hero-visual {
      max-width: 620px;
    }

    .services-hero h1 {
      max-width: 680px;
      font-size: 54px;
    }

    .services-hero p:not(.services-kicker),
    .services-intro p {
      font-size: 20px;
    }

    .section-heading h2,
    .services-cta h2 {
      font-size: 36px;
    }

    .services-grid,
    .process-grid,
    .services-cta {
      grid-template-columns: 1fr;
    }

    .service-card:nth-child(5) {
      grid-column: auto;
    }
  }

  @media (max-width: 620px) {
    .services-hero {
      min-height: 82vh;
      padding: 164px 18px 58px;
    }

    .services-hero h1 {
      font-size: 42px;
      line-height: 1.04;
    }

    .services-hero p:not(.services-kicker) {
      font-size: 18px;
    }

    .services-hero-visual {
      aspect-ratio: 16 / 10;
    }

    .services-intro p,
    .services-cta {
      width: min(100% - 36px, 1120px);
    }

    .services-section,
    .process-section {
      padding: 68px 18px;
    }

    .section-heading h2,
    .services-cta h2 {
      font-size: 31px;
      line-height: 1.14;
    }

    .service-card,
    .process-grid article {
      min-height: 0;
      padding: 24px;
    }

    .service-card span,
    .process-grid span {
      margin-bottom: 34px;
    }
  }
</style>
