---
import BaseLayout from "../layouts/BaseLayout.astro";
import contactContent from "../data/contact.json";

const {
  seoTitle,
  seoDescription,
  kicker,
  heroTitle,
  heroIntro,
  emailAddress,
  calendlyUrl,
  heroImage,
  heroImageAlt,
  statementText,
  optionsKicker,
  optionsTitle,
  optionsIntro,
  emailCardTitle,
  emailCardText,
  meetingCardTitle,
  meetingCardText,
} = contactContent;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical="https://designbysanne.nl/contact/"
  ogTitle={seoTitle}
  ogDescription={seoDescription}
  ogImage={heroImage}
>
  <main>
    <section class="contact-hero" aria-labelledby="contact-title">
      <div class="contact-hero-inner">
        <div class="contact-hero-copy">
          <p class="contact-kicker">{kicker}</p>
          <h1 id="contact-title">{heroTitle}</h1>
          <p>{heroIntro}</p>
          <div class="contact-actions" aria-label="Contactmogelijkheden">
            <a class="button button-primary" href={`mailto:${emailAddress}`}>Stuur een mail</a>
            <a class="button button-secondary" href={calendlyUrl}>Plan een kennismaking</a>
          </div>
        </div>
        <figure class="contact-hero-visual">
          <img src={heroImage} alt={heroImageAlt} />
        </figure>
      </div>
    </section>

    <section class="contact-statement" aria-label="Korte contacttekst">
      <p>{statementText}</p>
    </section>

    <section class="contact-options" id="kennismaken" aria-labelledby="contact-options-title">
      <div class="contact-options-copy">
        <p class="contact-kicker">{optionsKicker}</p>
        <h2 id="contact-options-title">{optionsTitle}</h2>
        <p>{optionsIntro}</p>
      </div>

      <div class="option-grid">
        <article class="option-card">
          <span>E-mail</span>
          <h3>{emailCardTitle}</h3>
          <p>{emailCardText}</p>
          <a class="button button-primary" href={`mailto:${emailAddress}`}>Stuur een mail</a>
        </article>

        <article class="option-card option-card-featured">
          <span>Kennismaken</span>
          <h3>{meetingCardTitle}</h3>
          <p>{meetingCardText}</p>
          <a class="button button-primary" href={calendlyUrl}>Plan een kennismaking</a>
        </article>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .contact-hero {
    min-height: 78vh;
    display: flex;
    align-items: center;
    padding: 190px 24px 82px;
    background:
      linear-gradient(90deg, rgba(32, 40, 47, 0.96), rgba(32, 40, 47, 0.76)),
      radial-gradient(circle at 82% 24%, rgba(220, 163, 38, 0.3), transparent 34%),
      #20282f;
    color: #ffffff;
  }

  .contact-hero-inner {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(300px, 0.76fr);
    gap: 56px;
    align-items: center;
  }

  .contact-kicker {
    margin: 0 0 14px;
    color: #dca326;
    font-size: 15px;
    font-weight: 900;
    text-transform: uppercase;
  }

  .contact-hero h1 {
    margin-bottom: 24px;
    font-size: 68px;
    line-height: 1;
    font-weight: 900;
  }

  .contact-hero p:not(.contact-kicker) {
    margin-bottom: 34px;
    color: rgba(255, 255, 255, 0.86);
    font-size: 22px;
    line-height: 1.55;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .contact-hero-visual {
    position: relative;
    margin: 0;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 8px;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
  }

  .contact-hero-visual::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(32, 40, 47, 0.02), rgba(32, 40, 47, 0.18));
    pointer-events: none;
  }

  .contact-hero-visual img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
  }

  .contact-statement {
    background: #627727;
    color: #ffffff;
  }

  .contact-statement p {
    width: min(1060px, calc(100% - 48px));
    margin: 0 auto;
    padding: 34px 0;
    font-size: 26px;
    line-height: 1.42;
    font-weight: 800;
  }

  .contact-options h2 {
    margin-bottom: 18px;
    color: #1f2a2f;
    font-size: 46px;
    line-height: 1.08;
    font-weight: 900;
  }

  .contact-options p:not(.contact-kicker) {
    color: #586167;
    font-size: 19px;
    line-height: 1.65;
  }

  .option-card {
    border: 1px solid rgba(32, 40, 47, 0.12);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(32, 40, 47, 0.08);
  }

  .option-card span {
    display: block;
    margin-bottom: 44px;
    color: #9a4d42;
    font-size: 18px;
    font-weight: 900;
  }

  .option-card h3 {
    margin-bottom: 14px;
    color: #627727;
    font-size: 27px;
    line-height: 1.18;
  }

  .option-card p {
    margin-bottom: 0;
    color: #586167;
    line-height: 1.62;
  }

  .contact-options {
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding: 94px 0 92px;
  }

  .contact-options-copy {
    max-width: 780px;
    margin-bottom: 32px;
  }

  .option-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .option-card {
    min-height: 314px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .option-card p {
    margin-bottom: 28px;
  }

  .option-card .button {
    margin-top: auto;
  }

  .option-card-featured {
    background: #dca326;
    color: #162024;
  }

  .option-card-featured span,
  .option-card-featured h3,
  .option-card-featured p {
    color: #162024;
  }

  .option-card-featured .button-primary {
    background: #ffffff;
    color: #627727;
  }

  @media (max-width: 980px) {
    .contact-hero-inner,
    .option-grid {
      grid-template-columns: 1fr;
    }

    .contact-hero-visual {
      max-width: 560px;
    }

    .contact-hero h1 {
      font-size: 54px;
    }

    .contact-hero p:not(.contact-kicker),
    .contact-statement p {
      font-size: 20px;
    }

    .contact-options h2 {
      font-size: 36px;
    }
  }

  @media (max-width: 620px) {
    .contact-hero {
      min-height: 82vh;
      padding: 164px 18px 58px;
    }

    .contact-hero h1 {
      font-size: 42px;
      line-height: 1.04;
    }

    .contact-hero p:not(.contact-kicker) {
      font-size: 18px;
    }

    .contact-hero-visual {
      aspect-ratio: 16 / 11;
    }

    .contact-statement p,
    .contact-options {
      width: min(100% - 36px, 1120px);
    }

    .contact-options {
      padding: 68px 0;
    }

    .contact-options h2 {
      font-size: 31px;
      line-height: 1.14;
    }

    .option-card {
      min-height: 0;
      padding: 24px;
    }

    .option-card span {
      margin-bottom: 34px;
    }
  }
</style>
