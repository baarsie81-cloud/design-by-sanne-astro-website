---
import BaseLayout from "../layouts/BaseLayout.astro";
import homeContent from "../data/home.json";

const {
  seoTitle,
  seoDescription,
  ogDescription,
  heroKicker,
  heroTitle,
  heroIntro,
  heroImage,
  primaryButtonLabel,
  secondaryButtonLabel,
  statementText,
  expertiseKicker,
  expertiseTitle,
  expertiseIntro,
  expertiseCards,
  serviceTags,
  aboutKicker,
  aboutTitle,
  aboutText,
  aboutLinkLabel,
  proofItems,
  logosKicker,
  logosTitle,
  clientLogos,
  workKicker,
  workTitle,
  workSteps,
  ctaKicker,
  ctaTitle,
  ctaText,
  ctaButtonLabel,
} = homeContent;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical="https://designbysanne.nl/"
  ogDescription={ogDescription}
  ogImage={heroImage}
>
  <main>
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-media" style={`--hero-image: url('${heroImage}')`} aria-hidden="true"></div>
        <div class="hero-shade" aria-hidden="true"></div>
        <div class="hero-content">
          <p class="eyebrow">{heroKicker}</p>
          <h1 id="hero-title">{heroTitle}</h1>
          <p class="hero-lead">{heroIntro}</p>
          <div class="hero-actions" aria-label="Belangrijkste acties">
            <a class="button button-primary" href="#expertise">{primaryButtonLabel}</a>
            <a class="button button-secondary" href="#kennismaken">{secondaryButtonLabel}</a>
          </div>
        </div>
      </section>

      <section class="statement" aria-label="Korte positionering">
        <div class="statement-inner">
          <p>{statementText}</p>
        </div>
      </section>

      <section class="section section-light" id="expertise" aria-labelledby="expertise-title">
        <div class="section-heading">
          <p class="section-kicker">{expertiseKicker}</p>
          <h2 id="expertise-title">{expertiseTitle}</h2>
          <p>{expertiseIntro}</p>
        </div>

        <div class="expertise-grid">
          {
            expertiseCards.map((card) => (
              <article class="expertise-card">
                <span>{card.number}</span>
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))
          }
        </div>

        <div class="service-line" aria-label="Diensten in het kort">
          {serviceTags.map((service) => <span>{service}</span>)}
        </div>
      </section>

      <section class="section section-split" aria-labelledby="about-title">
        <div class="split-copy">
          <p class="section-kicker">{aboutKicker}</p>
          <h2 id="about-title">{aboutTitle}</h2>
          <p>{aboutText}</p>
          <a class="text-link" href="/over-mij/">{aboutLinkLabel}</a>
        </div>
        <div class="proof-panel" aria-label="Waarom samenwerken">
          {proofItems.map((item) => (
            <div>
              <strong>{item.value}</strong>
              <span>{item.text}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="logo-section" aria-labelledby="logos-title">
        <div class="logo-heading">
          <p class="section-kicker">{logosKicker}</p>
          <h2 id="logos-title">{logosTitle}</h2>
        </div>
        <div class="logo-strip">
          {
            clientLogos.map((logo) => (
              <div class="logo-tile">
                <img src={logo.image} alt={logo.alt} loading="lazy" />
              </div>
            ))
          }
        </div>
      </section>

      <section class="section section-dark" aria-labelledby="work-title">
        <div class="section-heading section-heading-dark">
          <p class="section-kicker">{workKicker}</p>
          <h2 id="work-title">{workTitle}</h2>
        </div>
        <div class="work-steps">
          {workSteps.map((step) => (
            <article>
              <span>{step.label}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="final-cta" id="kennismaken" aria-labelledby="contact-title">
        <div>
          <p class="section-kicker">{ctaKicker}</p>
          <h2 id="contact-title">{ctaTitle}</h2>
          <p>{ctaText}</p>
        </div>
        <a class="button button-primary" href="/contact/">{ctaButtonLabel}</a>
      </section>
  </main>
</BaseLayout>

<style>
  :global(*) {
    box-sizing: border-box;
  }

  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body) {
    margin: 0;
    background: #f5f4ef;
    color: #20282f;
    font-family:
      Inter,
      ui-sans-serif,
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  :global(a) {
    color: inherit;
  }

  .site-header {
    position: fixed;
    z-index: 20;
    top: 0;
    left: 0;
    right: 0;
    display: grid;
    grid-template-columns: 178px 1fr auto;
    align-items: start;
    gap: 28px;
    min-height: 142px;
    padding: 18px 30px;
    color: #ffffff;
    background: linear-gradient(180deg, rgba(18, 26, 30, 0.78), rgba(18, 26, 30, 0));
  }

  .brand {
    display: flex;
    align-items: center;
    width: 178px;
    height: auto;
  }

  .brand img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    justify-content: center;
    gap: 28px;
    font-size: 15px;
    font-weight: 800;
  }

  .nav-links a,
  .header-cta,
  .text-link,
  .button {
    text-decoration: none;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 6px;
    font-weight: 900;
  }

  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: end;
    overflow: hidden;
    isolation: isolate;
    background: #20282f;
  }

  .hero-media {
    position: absolute;
    inset: 0;
    z-index: -3;
    background-image: var(--hero-image);
    background-size: cover;
    background-position: center 28%;
    transform: scale(1.02);
  }

  .hero-shade {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      linear-gradient(90deg, rgba(16, 24, 28, 0.88) 0%, rgba(16, 24, 28, 0.67) 38%, rgba(16, 24, 28, 0.18) 72%),
      linear-gradient(0deg, rgba(16, 24, 28, 0.72), rgba(16, 24, 28, 0.05) 50%);
  }

  .hero-content {
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding: 154px 0 90px;
    color: #ffffff;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 14px;
    color: #dca326;
    font-size: 15px;
    font-weight: 900;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 760px;
    margin-bottom: 24px;
    font-size: 72px;
    line-height: 0.98;
    font-weight: 900;
  }

  .hero-lead {
    max-width: 740px;
    margin-bottom: 34px;
    color: rgba(255, 255, 255, 0.9);
    font-size: 22px;
    line-height: 1.55;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
    padding: 0 24px;
    border-radius: 6px;
    font-weight: 900;
  }

  .button-primary {
    background: #dca326;
    color: #162024;
  }

  .button-secondary {
    border: 1px solid rgba(255, 255, 255, 0.52);
    color: #ffffff;
  }

  .statement {
    background: #627727;
    color: #ffffff;
  }

  .statement-inner {
    width: min(1060px, calc(100% - 48px));
    margin: 0 auto;
    padding: 34px 0;
  }

  .statement p {
    max-width: 980px;
    margin: 0;
    font-size: 26px;
    line-height: 1.42;
    font-weight: 800;
  }

  .section {
    padding: 94px 24px;
  }

  .section-light {
    background: #f5f4ef;
  }

  .section-heading {
    width: min(860px, 100%);
    margin: 0 auto 42px;
    text-align: center;
  }

  .section-heading h2,
  .split-copy h2,
  .logo-heading h2,
  .final-cta h2 {
    margin-bottom: 18px;
    color: #1f2a2f;
    font-size: 46px;
    line-height: 1.08;
    font-weight: 900;
  }

  .section-heading p:not(.section-kicker),
  .split-copy p,
  .final-cta p {
    color: #586167;
    font-size: 19px;
    line-height: 1.65;
  }

  .expertise-grid {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .expertise-card {
    min-height: 300px;
    padding: 28px;
    border: 1px solid rgba(32, 40, 47, 0.12);
    border-radius: 8px;
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(32, 40, 47, 0.08);
  }

  .expertise-card span {
    display: block;
    margin-bottom: 54px;
    color: #9a4d42;
    font-size: 18px;
    font-weight: 900;
  }

  .expertise-card h3 {
    margin-bottom: 14px;
    color: #627727;
    font-size: 25px;
    line-height: 1.18;
  }

  .expertise-card p {
    margin-bottom: 0;
    color: #586167;
    line-height: 1.62;
  }

  .service-line {
    width: min(1120px, 100%);
    margin: 28px auto 0;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    border-top: 1px solid rgba(32, 40, 47, 0.12);
    border-left: 1px solid rgba(32, 40, 47, 0.12);
  }

  .service-line span {
    min-height: 74px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    border-right: 1px solid rgba(32, 40, 47, 0.12);
    border-bottom: 1px solid rgba(32, 40, 47, 0.12);
    background: #faf9f5;
    color: #20282f;
    font-weight: 900;
    text-align: center;
  }

  .section-split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 480px);
    gap: 44px;
    align-items: stretch;
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding-left: 0;
    padding-right: 0;
  }

  .split-copy {
    align-self: center;
  }

  .text-link {
    display: inline-flex;
    margin-top: 10px;
    color: #627727;
    font-weight: 900;
  }

  .proof-panel {
    display: grid;
    gap: 1px;
    overflow: hidden;
    border-radius: 8px;
    background: rgba(32, 40, 47, 0.14);
    box-shadow: 0 18px 40px rgba(32, 40, 47, 0.08);
  }

  .proof-panel div {
    display: grid;
    grid-template-columns: 96px 1fr;
    align-items: center;
    min-height: 126px;
    padding: 24px;
    background: #ffffff;
  }

  .proof-panel strong {
    color: #dca326;
    font-size: 42px;
    line-height: 1;
  }

  .proof-panel span {
    color: #586167;
    line-height: 1.55;
    font-weight: 800;
  }

  .logo-section {
    padding: 86px 24px;
    background: #ffffff;
  }

  .logo-heading {
    width: min(760px, 100%);
    margin: 0 auto 32px;
    text-align: center;
  }

  .logo-strip {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 14px;
  }

  .logo-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 122px;
    padding: 18px;
    border: 1px solid rgba(32, 40, 47, 0.1);
    border-radius: 8px;
    background: #f5f4ef;
  }

  .logo-tile img {
    display: block;
    max-width: 160px;
    max-height: 62px;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .section-dark {
    background: #20282f;
    color: #ffffff;
  }

  .section-heading-dark h2 {
    color: #ffffff;
  }

  .work-steps {
    width: min(1120px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .work-steps article {
    min-height: 238px;
    padding: 28px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
  }

  .work-steps span {
    display: block;
    margin-bottom: 48px;
    color: #dca326;
    font-weight: 900;
  }

  .work-steps h3 {
    margin-bottom: 12px;
    font-size: 25px;
  }

  .work-steps p {
    margin-bottom: 0;
    color: rgba(255, 255, 255, 0.76);
    line-height: 1.62;
  }

  .final-cta {
    width: min(1120px, calc(100% - 48px));
    margin: 0 auto;
    padding: 86px 0;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 36px;
    align-items: center;
  }

  .final-cta p {
    max-width: 720px;
    margin-bottom: 0;
  }

  .footer {
    display: grid;
    grid-template-columns: minmax(180px, 1fr) auto minmax(180px, 1fr);
    align-items: center;
    gap: 32px;
    padding: 34px 42px;
    border-top: 1px solid rgba(32, 40, 47, 0.12);
    background: #ffffff;
    color: #20282f;
    font-weight: 900;
  }

  .footer-brand {
    display: grid;
    gap: 10px;
  }

  .footer img {
    width: 178px;
    height: auto;
    filter: brightness(0);
  }

  .footer-nav,
  .footer-socials {
    display: flex;
    align-items: center;
  }

  .footer-nav {
    justify-content: center;
    gap: 22px;
    font-size: 14px;
  }

  .footer-nav a,
  .footer-socials a {
    text-decoration: none;
  }

  .footer-nav a {
    color: #20282f;
  }

  .footer-socials {
    justify-content: end;
    gap: 14px;
  }

  .footer-socials a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(32, 40, 47, 0.14);
    border-radius: 999px;
    color: #20282f;
    transition:
      color 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .footer-socials a:hover {
    border-color: #d9a21b;
    background: #d9a21b;
    color: #ffffff;
  }

  .footer-socials svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 980px) {
    .site-header {
      grid-template-columns: 170px 1fr;
      padding: 14px 24px;
    }

    .nav-links {
      display: none;
    }

    .header-cta {
      justify-self: end;
    }

    h1 {
      max-width: 620px;
      font-size: 56px;
    }

    .hero-lead,
    .statement p {
      font-size: 20px;
    }

    .section-heading h2,
    .split-copy h2,
    .logo-heading h2,
    .final-cta h2 {
      font-size: 36px;
    }

    .expertise-grid,
    .work-steps,
    .section-split,
    .final-cta {
      grid-template-columns: 1fr;
    }

    .service-line,
    .logo-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-brand,
    .footer-nav,
    .footer-socials {
      justify-content: center;
    }

    .footer img {
      margin: 0 auto;
    }
  }

  @media (max-width: 620px) {
    .site-header {
      position: absolute;
      grid-template-columns: 1fr;
      gap: 12px;
      min-height: 0;
      padding: 18px;
    }

    .brand {
      width: 154px;
      height: auto;
    }

    .header-cta {
      justify-self: start;
      min-height: 38px;
      padding: 0 14px;
      font-size: 14px;
    }

    .hero {
      min-height: 92vh;
    }

    .hero-media {
      background-position: 60% center;
    }

    .hero-shade {
      background:
        linear-gradient(90deg, rgba(16, 24, 28, 0.88), rgba(16, 24, 28, 0.42)),
        linear-gradient(0deg, rgba(16, 24, 28, 0.84), rgba(16, 24, 28, 0.1) 62%);
    }

    .hero-content {
      width: min(100% - 36px, 1120px);
      padding: 164px 0 58px;
    }

    h1 {
      font-size: 43px;
      line-height: 1.02;
    }

    .hero-lead {
      font-size: 18px;
    }

    .hero-actions,
    .button {
      width: 100%;
    }

    .section {
      padding: 68px 18px;
    }

    .statement-inner,
    .section-split,
    .final-cta {
      width: min(100% - 36px, 1120px);
    }

    .section-heading h2,
    .split-copy h2,
    .logo-heading h2,
    .final-cta h2 {
      font-size: 31px;
      line-height: 1.14;
    }

    .expertise-card,
    .work-steps article {
      min-height: 0;
      padding: 24px;
    }

    .expertise-card span,
    .work-steps span {
      margin-bottom: 34px;
    }

    .service-line,
    .logo-strip {
      grid-template-columns: 1fr;
    }

    .logo-tile {
      min-height: 100px;
    }

    .proof-panel div {
      grid-template-columns: 72px 1fr;
      min-height: 112px;
      padding: 20px;
    }

    .proof-panel strong {
      font-size: 34px;
    }

    .footer {
      padding: 30px 18px;
    }

    .footer-nav {
      flex-wrap: wrap;
      gap: 14px 20px;
    }
  }
</style>
